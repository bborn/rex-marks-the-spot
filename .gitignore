# Task worktrees
.task-worktrees

# Python
.venv/
__pycache__/
*.pyc

# Blender backup files (autosaves)
*.blend1
*.blend2

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temporary render outputs (keep final renders in renders/)
tmp/
temp/

# Node modules (for website)
node_modules/

# Environment files
.env
.env.local
*credentials.env

# Large binary assets (stored in R2 instead)
# Storyboard images
docs/storyboards/**/panels/*.png
storyboards/**/panels/*.png

# Character turnarounds and concept art
assets/characters/**/*.png
assets/characters/**/*.jpg
output/**/*.png
output/**/*.jpg
output/**/*.glb
output/**/*.fbx
output/**/*.obj
output/**/*.mp4
output/**/*.json

# Asset Bible: image binaries mirror to R2; only JSON/MD lives in git
asset-bible/**/*.png
asset-bible/**/*.jpg
asset-bible/**/*.jpeg
asset-bible/**/*.webp

# Shot-validator artifacts: video footage + extracted keyframes are large
# and live in R2. The validator code + the markdown/JSON reports it produces
# stay in git so the report itself is reviewable.
footage/
